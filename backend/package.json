{
  "name": "@caresync/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CareSync backend: AWS Lambda functions managed by Serverless Framework.",
  "main": "src/handlers/health.ts",
  "scripts": {
    "dev": "serverless offline start",
    "build": "tsc --noEmit",
    "package": "serverless package",
    "deploy": "serverless deploy",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "fetch-jwks": "node scripts/fetch-jwks.mjs",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.16.5",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "serverless": "^4.4.7",
    "serverless-esbuild": "^1.55.1",
    "serverless-offline": "^14.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1066.0",
    "aws-jwt-verify": "^5.2.1",
    "mysql2": "^3.22.5"
  }
}
