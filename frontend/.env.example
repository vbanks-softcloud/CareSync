# Copy this file to `.env.local` and fill in real values from your Cognito
# CloudFormation stack outputs to enable real AWS Cognito authentication.
#
# If these are left blank, the app falls back to a local "mock" auth that
# stores `{email}` in localStorage. This is intentional so `npm run dev`
# works before the Cognito stack is deployed.

# Cognito User Pool ID (e.g. ca-central-1_aBcD1234)
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (e.g. 7abc...xyz)
VITE_COGNITO_USER_POOL_CLIENT_ID=

# AWS region where the User Pool lives (must match the prefix of the pool ID)
VITE_COGNITO_REGION=ca-central-1
