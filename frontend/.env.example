# Copy this file to `.env.local` and fill in real values for local dev.
# All three blocks must be set for the dashboard to load real data —
# leaving Cognito blank kicks the app into a localStorage mock that's only
# useful for UI work without auth, and leaving the API URL blank surfaces
# an ApiNotConfigured error as soon as the dashboard tries to list patients.

# ---- Cognito ----
# Cognito User Pool ID (e.g. us-east-1_aIqAshPg1).
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (e.g. 709do2jdofjreluscm109kgdsp).
VITE_COGNITO_USER_POOL_CLIENT_ID=

# AWS region where the User Pool lives (must match the prefix of the pool ID).
VITE_COGNITO_REGION=us-east-1

# ---- API ----
# Base URL of the caresync-backend HTTP API. After `npx serverless deploy`,
# grab the URL printed under "endpoints:" (without any path suffix).
# Example: https://3nt6bbgy1e.execute-api.us-east-1.amazonaws.com
#
# The Vite dev server runs on http://localhost:8080 (pinned in
# vite.config.ts); make sure that origin is in the backend's CORS
# allowedOrigins list or the browser will block API calls in dev.
VITE_API_BASE_URL=
